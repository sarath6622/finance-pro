# MongoDB connection string (Atlas or local mongod)
MONGODB_URI=mongodb://127.0.0.1:27017/finance-tracker
MONGODB_DB=finance-tracker

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Single-owner credentials (P0 dev). Replace with real provider in production.
OWNER_EMAIL=sarath@example.com
OWNER_PASSWORD_HASH=replace-with-bcrypt-hash

# Optional: Google OAuth (recommended for prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
