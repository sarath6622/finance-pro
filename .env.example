# Required: MongoDB Atlas connection string (or local mongod for dev)
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/finance-tracker
MONGODB_DB=finance-tracker

# Required: NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
# Set to your deployed URL in production (e.g. https://finance.example.com)
# Vercel auto-provides VERCEL_URL but NextAuth wants the explicit one for callbacks.
NEXTAUTH_URL=http://localhost:3000

# Required: Single-owner credentials (set OWNER_EMAIL to your own email,
# then run `npm run hash-password <your-password>` and paste the output here).
OWNER_EMAIL=you@example.com
OWNER_PASSWORD_HASH=replace-with-output-of-npm-run-hash-password

# Optional: Google OAuth (not yet wired in code; placeholder)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
